# DataForSEO Google Trends API
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Optional AI analysis
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Notification webhooks. Configure either or both.
FEISHU_WEBHOOK_URL=
WECOM_WEBHOOK_URL=

# Runtime defaults
GAMESEO_DB_PATH=data/gameseo.sqlite3
GAMESEO_CONFIG=config/sites.example.json

# Supabase/Postgres persistence. If set, this overrides local SQLite.
# Use the Supabase Postgres connection string, not the Supabase anon key.
SUPABASE_DB_URL=
